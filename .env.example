# Shared environment variables for local development.
# Copy to .env in this directory and restart `npm run dev` after changes.

# Spoonacular API (backend proxy only — never expose to frontend)
SPOONACULAR_API_KEY=4e3f8621542e4fcaa847fa34e32a10b9

# Frontend debug logging for meal plan generation (optional)
VITE_MEAL_PLAN_DEBUG=true

# Backend
PORT=3001

# Salling Group API (backend only — never expose to frontend)
SALLING_API_TOKEN=your_token_here
SALLING_API_BASE_URL=https://api.sallinggroup.com/v1
CACHE_TTL_SECONDS=900
REQUEST_TIMEOUT_MS=8000

# Future
# OPENAI_API_KEY=
